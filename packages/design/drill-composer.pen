                          "type": "icon_font",
                          "id": "tool-player-icon",
                          "width": 18,
                          "height": 18,
                          "iconFontName": "circle-user",
                          "iconFontFamily": "lucide",
                          "fill": "$accent.figma"
                        },
                        {
                          "type": "text",
                          "id": "tool-player-label",
                          "fill": "$chrome.text",
                          "content": "Player",
                          "fontFamily": "Inter",
                          "fontSize": 12,
                          "fontWeight": "500"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "tool-cone",
                      "width": "fill_container",
                      "height": 36,
                      "fill": "transparent",
                      "cornerRadius": 6,
                      "gap": 10,
                      "padding": 10,
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "polygon",
                          "polygonCount": 3,
                          "id": "tool-cone-icon",
                          "rotation": 180,
                          "fill": "$color.cone",
                          "width": 16,
                          "height": 16
                        },
                        {
                          "type": "text",
                          "id": "tool-cone-label",
                          "fill": "$chrome.textMuted",
