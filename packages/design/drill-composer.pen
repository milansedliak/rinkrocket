{
  "version": "2.11",
  "children": [
    {
      "type": "frame",
      "id": "artboard-drill-composer-v1",
      "x": 0,
      "y": 0,
      "name": "Drill composer · 1920×1080 (Figma-style)",
      "clip": true,
      "width": 1920,
      "height": 1080,
      "fill": "$chrome.bg",
      "layout": "vertical",
      "children": [
        {
          "type": "frame",
          "id": "header",
          "width": "fill_container",
          "height": 52,
          "fill": "$chrome.bg",
          "stroke": {
            "align": "inside",
            "thickness": {
              "bottom": 1
            },
            "fill": "$chrome.border"
          },
          "padding": [
            0,
            10
          ],
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "id": "header-menu",
              "width": 40,
              "height": 40,
              "fill": "transparent",
              "cornerRadius": 6,
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                {
                  "type": "icon_font",
                  "id": "header-menu-icon",
                  "width": 20,
                  "height": 20,
                  "iconFontName": "menu",
                  "iconFontFamily": "lucide",
                  "fill": "$chrome.textMuted"
                }
              ]
            },
            {
              "type": "frame",
              "id": "header-logo",
              "width": 28,
              "height": 28,
              "fill": "$accent.figma",
              "cornerRadius": 6,
              "justifyContent": "center",
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "header-logo-letter",
                  "fill": "#FFFFFF",
                  "content": "R",
                  "fontFamily": "Inter",
                  "fontSize": 13,
                  "fontWeight": "700"
                }
              ]
            },
            {
              "type": "rectangle",
              "id": "header-sep-1",
              "fill": "$chrome.border",
              "width": 1,
              "height": 22
            },
            {
              "type": "frame",
              "id": "header-file-block",
              "height": 40,
              "fill": "transparent",
              "cornerRadius": 6,
              "gap": 6,
              "padding": [
                0,
                10
              ],
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "header-file-name",
                  "fill": "$chrome.text",
                  "content": "NZ breakout — timing",
                  "fontFamily": "Inter",
                  "fontSize": 13,
                  "fontWeight": "500"
                },
                {
                  "type": "icon_font",
                  "id": "header-file-chevron",
                  "width": 14,
                  "height": 14,
                  "iconFontName": "chevron-down",
                  "iconFontFamily": "lucide",
                  "fill": "$chrome.textDim"
                }
              ]
            },
            {
              "type": "frame",
              "id": "header-spacer",
              "width": "fill_container",
              "height": 8,
              "fill": "transparent"
            },
            {
              "type": "frame",
              "id": "header-draft-pill",
              "fill": "$chrome.bgRaised",
              "cornerRadius": 6,
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$chrome.border"
              },
              "gap": 6,
              "padding": [
                6,
                10
              ],
              "alignItems": "center",
              "children": [
                {
                  "type": "ellipse",
                  "id": "header-draft-dot",
                  "fill": "$chrome.textDim",
                  "width": 6,
                  "height": 6
                },
                {
                  "type": "text",
                  "id": "header-draft-label",
                  "fill": "$chrome.textMuted",
                  "content": "Draft",
                  "fontFamily": "Inter",
                  "fontSize": 11,
                  "fontWeight": "600"
                }
              ]
            },
            {
              "type": "frame",
              "id": "header-zoom",
              "fill": "$chrome.bgRaised",
              "cornerRadius": 6,
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$chrome.border"
              },
              "gap": 4,
              "padding": [
                6,
                10
              ],
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "id": "header-zoom-val",
                  "fill": "$chrome.textMuted",
                  "content": "100%",
                  "fontFamily": "Inter",
                  "fontSize": 12,
                  "fontWeight": "500"
                },
                {
                  "type": "icon_font",
                  "id": "header-zoom-chev",
                  "width": 12,
                  "height": 12,
                  "iconFontName": "chevron-down",
                  "iconFontFamily": "lucide",
                  "fill": "$chrome.textDim"
                }
              ]
            },
            {
              "type": "frame",
              "id": "header-preview",
              "fill": "transparent",
              "cornerRadius": 6,
              "stroke": {
                "align": "inside",
                "thickness": 1,
                "fill": "$chrome.border"
              },
              "gap": 8,
              "padding": [
                8,
                14
              ],
              "alignItems": "center",
              "children": [
                {
                  "type": "icon_font",
                  "id": "header-preview-icon",
                  "width": 14,
                  "height": 14,
                  "iconFontName": "play",
                  "iconFontFamily": "lucide",
                  "fill": "$chrome.text"
                },
                {
                  "type": "text",
                  "id": "header-preview-label",
                  "fill": "$chrome.text",
                  "content": "Present",
                  "fontFamily": "Inter",
                  "fontSize": 12,
                  "fontWeight": "600"
                }
              ]
            },
            {
              "type": "frame",
              "id": "header-share",
              "fill": "$accent.share",
              "cornerRadius": 6,
              "gap": 6,
              "padding": [
                8,
                16
              ],
              "alignItems": "center",
              "children": [
                {
                  "type": "icon_font",
                  "id": "header-share-icon",
                  "width": 14,
                  "height": 14,
                  "iconFontName": "share-2",
