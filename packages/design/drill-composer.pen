              ]
            },
            {
              "type": "ellipse",
              "id": "header-avatar",
              "fill": {
                "type": "gradient",
                "gradientType": "linear",
                "enabled": true,
                "rotation": 135,
                "size": {
                  "height": 1
                },
                "colors": [
                  {
                    "color": "#7C6CF0",
                    "position": 0
                  },
                  {
                    "color": "#0D99FF",
                    "position": 1
                  }
                ]
              },
              "width": 30,
              "height": 30,
              "stroke": {
                "align": "outside",
                "thickness": 2,
                "fill": "$chrome.bg"
              }
            }
          ]
        },
        {
          "type": "frame",
          "id": "body",
          "width": "fill_container",
