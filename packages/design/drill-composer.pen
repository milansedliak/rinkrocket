                          "fontWeight": "600",
                          "letterSpacing": 0.5
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "palette-tab-layers",
                      "height": 32,
                      "fill": "transparent",
                      "padding": [
                        0,
                        12
                      ],
                      "justifyContent": "center",
