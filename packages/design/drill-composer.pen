                          "id": "insp-tags-row",
                          "width": "fill_container",
                          "height": 32,
                          "gap": 8,
                          "children": [
                            {
                              "type": "frame",
                              "id": "tag-breakout",
                              "fill": "$chrome.bg",
                              "cornerRadius": 6,
                              "stroke": {
                                "align": "inside",
                                "thickness": 1,
                                "fill": "$chrome.border"
                              },
                              "padding": [
                                6,
                                10
                              ],
                              "alignItems": "center",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "tag-breakout-text",
                                  "fill": "$chrome.textMuted",
                                  "content": "breakout",
                                  "fontFamily": "Inter",
                                  "fontSize": 11,
                                  "fontWeight": "500"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "tag-timing",
                              "fill": "$chrome.bg",
                              "cornerRadius": 6,
                              "stroke": {
                                "align": "inside",
                                "thickness": 1,
                                "fill": "$chrome.border"
                              },
                              "padding": [
                                6,
                                10
                              ],
                              "alignItems": "center",
                              "children": [
                                {
                                  "type": "text",
                                  "id": "tag-timing-text",
                                  "fill": "$chrome.textMuted",
                                  "content": "timing",
                                  "fontFamily": "Inter",
                                  "fontSize": 11,
                                  "fontWeight": "500"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "rectangle",
                      "id": "insp-divider-2",
                      "fill": "$chrome.border",
                      "width": "fill_container",
                      "height": 1
                    },
                    {
                      "type": "frame",
                      "id": "insp-model-note",
                      "width": "fill_container",
                      "fill": "$chrome.bg",
                      "cornerRadius": 6,
                      "stroke": {
                        "align": "inside",
                        "thickness": 1,
                        "fill": "$chrome.border"
                      },
                      "layout": "vertical",
                      "gap": 6,
                      "padding": 12,
                      "children": [
                        {
                          "type": "text",
                          "id": "insp-model-note-title",
                          "fill": "$chrome.textDim",
                          "content": "Data model",
                          "fontFamily": "Inter",
                          "fontSize": 10,
                          "fontWeight": "600",
                          "letterSpacing": 0.5
                        },
                        {
                          "type": "text",
                          "id": "insp-model-note-text",
                          "fill": "$chrome.textMuted",
                          "textGrowth": "fixed-width",
                          "width": 248,
                          "content": "Drill → name, description?, duration?, tags[], canvas_state (frames + elements). Aligns with docs/specs/drill-system.md.",
                          "lineHeight": 1.45,
                          "fontFamily": "Inter",
                          "fontSize": 11,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ],
