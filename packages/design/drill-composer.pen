                      "cornerRadius": 6,
                      "gap": 10,
                      "padding": 10,
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "icon_font",
                          "id": "tool-path-icon",
                          "width": 18,
                          "height": 18,
                          "iconFontName": "pencil-line",
                          "iconFontFamily": "lucide",
                          "fill": "$chrome.textDim"
                        },
                        {
                          "type": "text",
                          "id": "tool-path-label",
                          "fill": "$chrome.textMuted",
                          "content": "Vector path",
                          "fontFamily": "Inter",
                          "fontSize": 12,
                          "fontWeight": "500"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "tool-zone",
                      "width": "fill_container",
                      "height": 36,
                      "fill": "transparent",
                      "cornerRadius": 6,
                      "gap": 10,
                      "padding": 10,
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "icon_font",
                          "id": "tool-zone-icon",
                          "width": 18,
                          "height": 18,
                          "iconFontName": "layout-template",
                          "iconFontFamily": "lucide",
                          "fill": "$chrome.textDim"
                        },
                        {
                          "type": "text",
                          "id": "tool-zone-label",
                          "fill": "$chrome.textMuted",
                          "content": "Zone",
                          "fontFamily": "Inter",
                          "fontSize": 12,
                          "fontWeight": "500"
                        }
                      ]
                    },
                    {
                      "type": "frame",
                      "id": "tool-text",
                      "width": "fill_container",
                      "height": 36,
                      "fill": "transparent",
                      "cornerRadius": 6,
                      "gap": 10,
                      "padding": 10,
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "icon_font",
                          "id": "tool-text-icon",
                          "width": 18,
                          "height": 18,
                          "iconFontName": "type",
                          "iconFontFamily": "lucide",
                          "fill": "$chrome.textDim"
                        },
                        {
                          "type": "text",
                          "id": "tool-text-label",
                          "fill": "$chrome.textMuted",
                          "content": "Text",
                          "fontFamily": "Inter",
                          "fontSize": 12,
                          "fontWeight": "500"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "palette-footnote",
                  "width": "fill_container",
                  "height": "fill_container",
                  "fill": "transparent",
                  "layout": "vertical",
                  "padding": [
                    12,
                    12,
                    16,
                    12
                  ],
                  "justifyContent": "end",
                  "children": [
                    {
                      "type": "text",
                      "id": "palette-footnote-text",
                      "fill": "$chrome.textDim",
                      "textGrowth": "fixed-width",
                      "width": 220,
                      "content": "Place tools on the canvas. Frames = drill steps. Stored as canvas_state on Drill.",
                      "lineHeight": 1.45,
                      "fontFamily": "Inter",
                      "fontSize": 10,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            },
            {
              "type": "frame",
              "id": "canvas-column",
              "width": "fill_container",
              "height": "fill_container",
              "fill": "$canvas.workspace",
              "layout": "vertical",
              "children": [
                {
                  "type": "frame",
                  "id": "excal-toolbar-wrap",
                  "name": "Excalidraw-style shape toolbar",
                  "width": "fill_container",
                  "height": 86,
                  "fill": "$canvas.workspace",
                  "stroke": {
                    "align": "inside",
                    "thickness": {
                      "bottom": 1
                    },
                    "fill": "#ECECEC"
                  },
                  "layout": "vertical",
                  "gap": 6,
                  "padding": [
                    10,
                    16,
                    6,
                    16
                  ],
                  "justifyContent": "center",
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "frame",
                      "id": "excal-toolbar-dock",
                      "fill": "$excal.dock.bg",
                      "cornerRadius": 10,
                      "stroke": {
                        "align": "inside",
                        "thickness": 1,
                        "fill": "$excal.dock.stroke"
                      },
                      "effect": {
                        "type": "shadow",
                        "shadowType": "outer",
                        "color": "#00000018",
                        "offset": {
                          "x": 0,
                          "y": 2
                        },
                        "blur": 12
                      },
                      "gap": 2,
                      "padding": [
                        6,
                        8
                      ],
                      "alignItems": "center",
                      "children": [
                        {
                          "type": "frame",
                          "id": "excal-tool-select",
                          "width": 36,
                          "height": 36,
                          "fill": "$excal.toolSelected",
                          "cornerRadius": 8,
                          "stroke": {
                            "align": "inside",
                            "thickness": 1,
                            "fill": "$excal.toolAccent"
                          },
                          "justifyContent": "center",
                          "alignItems": "center",
                          "children": [
                            {
                              "type": "icon_font",
                              "id": "excal-tool-select-icon",
                              "width": 20,
                              "height": 20,
                              "iconFontName": "mouse-pointer-2",
                              "iconFontFamily": "lucide",
                              "fill": "$excal.toolAccent"
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "excal-tool-hand",
                          "width": 36,
                          "height": 36,
                          "fill": "transparent",
                          "cornerRadius": 8,
                          "justifyContent": "center",
                          "alignItems": "center",
                          "children": [
                            {
                              "type": "icon_font",
                              "id": "excal-tool-hand-icon",
                              "width": 20,
                              "height": 20,
                              "iconFontName": "hand",
                              "iconFontFamily": "lucide",
                              "fill": "$excal.iconMuted"
                            }
                          ]
                        },
                        {
                          "type": "rectangle",
                          "id": "excal-sep-1",
                          "fill": "$excal.dock.stroke",
                          "width": 1,
                          "height": 22
                        },
                        {
                          "type": "frame",
                          "id": "excal-tool-rect",
