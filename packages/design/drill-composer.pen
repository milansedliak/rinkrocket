                  "children": [
                    {
                      "type": "icon_font",
                      "id": "rail-move-icon",
                      "width": 18,
                      "height": 18,
                      "iconFontName": "mouse-pointer-2",
                      "iconFontFamily": "lucide",
                      "fill": "$chrome.text"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "rail-hand",
                  "width": 36,
                  "height": 36,
                  "fill": "transparent",
                  "cornerRadius": 6,
                  "justifyContent": "center",
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "icon_font",
                      "id": "rail-hand-icon",
                      "width": 18,
                      "height": 18,
                      "iconFontName": "hand",
                      "iconFontFamily": "lucide",
                      "fill": "$chrome.textDim"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "rail-scale",
                  "width": 36,
                  "height": 36,
                  "fill": "transparent",
                  "cornerRadius": 6,
                  "justifyContent": "center",
                  "alignItems": "center",
                  "children": [
                    {
                      "type": "icon_font",
                      "id": "rail-scale-icon",
                      "width": 18,
                      "height": 18,
                      "iconFontName": "scan",
                      "iconFontFamily": "lucide",
                      "fill": "$chrome.textDim"
